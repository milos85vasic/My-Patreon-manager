# Server
PORT=8080
GIN_MODE=debug
LOG_LEVEL=info

# Patreon API
PATREON_CLIENT_ID=your_client_id_here
PATREON_CLIENT_SECRET=your_client_secret_here
PATREON_ACCESS_TOKEN=your_access_token_here
PATREON_REFRESH_TOKEN=your_refresh_token_here
PATREON_CAMPAIGN_ID=your_campaign_id_here

# OAuth
REDIRECT_URI=http://localhost:8080/callback

# Database
DB_DRIVER=sqlite
DB_PATH=user/db/patreon_manager.db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=my_patreon_manager

# Content Generation
CONTENT_QUALITY_THRESHOLD=0.75
LLM_DAILY_TOKEN_BUDGET=100000
# Global cap on concurrent in-flight LLM calls across all providers.
LLM_CONCURRENCY=8
CONTENT_TIER_MAPPING_STRATEGY=linear

# HMAC Secret (for signed URLs)
HMAC_SECRET=change_this_to_a_random_secret

# Git Provider Tokens
GITHUB_TOKEN=
GITHUB_TOKEN_SECONDARY=
# GITHUB_ORGS=my-org,other-org,* (wildcard for all orgs)
GITLAB_TOKEN=
GITLAB_TOKEN_SECONDARY=
GITLAB_BASE_URL=https://gitlab.com
# GITLAB_GROUPS=my-group,subgroup/*
GITFLIC_TOKEN=
GITFLIC_TOKEN_SECONDARY=
# GITFLIC_ORGS=my-org
GITVERSE_TOKEN=
GITVERSE_TOKEN_SECONDARY=
# GITVERSE_ORGS=my-org

# Repository Filtering
# Set to true to include private repositories in sync/scan/generate.
PROCESS_PRIVATE_REPOSITORIES=false
# Minimum months of commit activity. Repos inactive longer are skipped.
# Default: 18 months. Set to 0 to disable.
MIN_MONTHS_COMMIT_ACTIVITY=18

# User Workspace
# Root directory for all user data (db, images, content, templates).
USER_WORKSPACE_DIR=user

# Grace Period
GRACE_PERIOD_HOURS=24

# Audit store backend: "ring" (bounded in-memory, default) or "sqlite"
# (persists into the shared database connection).
AUDIT_STORE=ring

# Video Generation
VIDEO_GENERATION_ENABLED=false

# PDF Rendering — when true, the content generator will register the PDFRenderer
# alongside Markdown/HTML. Falls back to HTML bytes if no Chromium/Chrome binary
# is on PATH.
PDF_RENDERING_ENABLED=false

# Admin
ADMIN_KEY=
# Optional reviewer key for preview UI approve/reject/edit endpoints.
# Provides lower-privilege access (cannot change config or access /admin/*).
REVIEWER_KEY=

# Webhook HMAC shared secret. Used by /webhook/* signature validation
# (GitHub: X-Hub-Signature-256; GitLab/Generic: bearer token). Phase 2 Task 6
# will refine per-provider verification.
WEBHOOK_HMAC_SECRET=

# Per-IP rate limit applied to /webhook/*, /admin/*, and /download/:content_id
# — sustained rate in requests/sec and short-term burst budget. Stale IP
# entries are evicted by a supervised background sweeper after 10 minutes.
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# --- LLMsVerifier (REQUIRED for content generation) ---
# The LLMsVerifier service tests all LLM providers, scores models, and provides
# a ranked list. ALL LLM calls route through this service per constitution principle IV.
# See: https://github.com/vasic-digital/LLMsVerifier
LLMSVERIFIER_ENDPOINT=http://localhost:9099
LLMSVERIFIER_API_KEY=your_llmsverifier_api_key_here

# --- Illustration Generation ---
# Per-article image generation runs automatically between the quality gate and
# rendering. When ILLUSTRATION_ENABLED=true but no image-provider key is set,
# articles are still published; the illustration step logs a warning and is
# skipped. Opt out per-repo via `.repoignore` (no-illustration) or `.illustyle`.
ILLUSTRATION_ENABLED=true
ILLUSTRATION_DEFAULT_STYLE=modern tech illustration, clean lines, professional
ILLUSTRATION_DEFAULT_SIZE=1792x1024
ILLUSTRATION_DEFAULT_QUALITY=hd
ILLUSTRATION_DIR=./data/illustrations
# Order in which configured image providers are tried. The first provider with
# its required keys set becomes primary; the rest form the fallback chain.
IMAGE_PROVIDER_PRIORITY=dalle,stability,midjourney,openai_compat

# --- Image Providers (set at least one; all others are optional) ---
# DALL-E 3 (via OpenAI). Required: OPENAI_API_KEY.
# OPENAI_BASE_URL overrides the DALL-E API endpoint when set; leave empty
# to use the default https://api.openai.com/v1.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Stability AI (SDXL). Required: STABILITY_AI_API_KEY.
# STABILITY_AI_BASE_URL overrides the Stability API endpoint when set;
# leave empty to use the default https://api.stability.ai/v2beta.
STABILITY_AI_API_KEY=
STABILITY_AI_BASE_URL=

# Midjourney via third-party proxy. Both key and endpoint are required.
MIDJOURNEY_API_KEY=
MIDJOURNEY_ENDPOINT=

# OpenAI-compatible image endpoint (Venice, Together, etc.). Key and base URL
# are both required. Model is optional; when set it is sent in the request body.
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=

# --- Security scanning (Phase 0) ---
# Obtain from https://app.snyk.io/account and https://sonarcloud.io/account/security/
SNYK_TOKEN=your_snyk_token_here
SONAR_TOKEN=your_sonar_token_here
SONAR_HOST_URL=http://localhost:9000

# --- Process Pipeline ---
# Max pending_review drafts allowed per repo before `process` skips it.
MAX_ARTICLES_PER_REPO=1
# Global cap per `process` invocation. Empty = unlimited.
MAX_ARTICLES_PER_RUN=
# Per-repo retention. Published + approved + pending_review are pinned.
MAX_REVISIONS=20
# Bump when generator prompts/models change to invalidate the LLM/image cache.
GENERATOR_VERSION=v1
# Skip Patreon drift-check if the post was verified within this window. 0 = always.
DRIFT_CHECK_SKIP_MINUTES=30
# Lock heartbeat interval seconds. Stale > 10x = reclaimable.
PROCESS_LOCK_HEARTBEAT_SECONDS=30
